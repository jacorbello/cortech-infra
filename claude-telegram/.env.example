# Telegram channel env for the Claude Code telegram plugin.
# Real file lives at: /home/claude/.claude/channels/telegram/.env  (owned by claude, mode 0600)
# The plugin reads it directly — it is NOT a process EnvironmentFile.
# Pull the value from Infisical (dev); never commit the real token.
TELEGRAM_BOT_TOKEN=
# Optional: restrict the bot to a single chat, if the plugin supports it.
# TELEGRAM_CHAT_ID=
